generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────
enum Role {
  USER
  TBN_STAFF
  ADMIN
}

enum Plan {
  STARTER
  PRO
  MANAGED
}

// ─── NextAuth models ─────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?            // null for Google-only auth (TBN staff)
  role            Role      @default(USER)
  plan            Plan?              // null = no active plan (shouldn't happen for registered users)
  stripeCustomerId String?  @unique
  stripeSubId     String?            // active Stripe Subscription ID
  planExpiresAt   DateTime?          // for invite-based plans with expiry
  inviteCode      String?            // which invite code was used
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  accounts        Account[]
  sessions        Session[]
  projects        Project[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Password Reset ──────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Invite Links ────────────────────────────────────────────────────
model InviteLink {
  id        String   @id @default(cuid())
  code      String   @unique       // e.g. "BETA-PRO-2026-xyz"
  plan      Plan                    // which plan gets activated
  maxUses   Int      @default(1)   // 1 = single invitation
  usedCount Int      @default(0)
  expiresAt DateTime?
  note      String?               // "Für Kunde XYZ"
  createdBy String                // Admin User-ID
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── LLM Radar project tracking ─────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  domain      String   @unique
  name        String
  description String?
  industry    String?  // e.g. "B2B PR", "SaaS", "MedTech"
  coreTopics  String?  @db.Text // Comma-separated core topics
  pagesCrawled Int     @default(0) // Track how many pages have been crawled
  userId      String?  // Owner of the project (null for legacy projects)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Monitoring settings
  monitoringEnabled  Boolean  @default(false)
  monitoringInterval String   @default("weekly") // "weekly", "biweekly", "monthly"
  lastDiagnoseAt     DateTime?
  alertThreshold     Int      @default(10) // Score drop % that triggers alert
  alertEmail         String?  // Email for alerts (optional)
  alertSlack         Boolean  @default(true) // Post alerts to Slack
  competitors        String?  @db.Text // JSON array of competitor domains

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  diagnoses   Diagnosis[]

  @@index([userId])
}

model Diagnosis {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  score         Int      // 0-100
  scoreCitation Int      // max 30
  scoreTech     Int      // max 20
  scoreSchema   Int      // max 20
  scoreContent  Int      // max 15
  scoreFresh    Int      // max 15
  reportJson    String?  @db.Text // Full report JSON from n8n
  agenticBrowsingJson String? @db.Text // Lighthouse Agentic Browsing audit results JSON
  createdAt     DateTime @default(now())

  @@index([projectId, createdAt])
}

// Waitlist for Closed Beta
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("landing_page")
  createdAt DateTime @default(now())
}

// MCP Request Analytics — logs every external AI query to the Knowledge API
model McpRequest {
  id        String   @id @default(cuid())
  domain    String   // Which project domain was queried
  tool      String   // MCP tool name (search, get_entity, list_services etc.)
  engine    String   @default("Unknown") // Detected AI engine from User-Agent
  userAgent String   @default("") @db.Text
  sourceIp  String   @default("")
  createdAt DateTime @default(now())

  @@index([domain, createdAt])
  @@index([domain, engine])
}
