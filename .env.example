# Database (PostgreSQL for NextAuth sessions & project metadata)
DATABASE_URL="postgresql://user:password@localhost:5432/llmradar"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://llmradar.de"

# Google OAuth (only for TBN staff @tbnpr.de)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Baserow (Knowledge Database)
BASEROW_URL="https://brain.tbnpr.net"
BASEROW_EMAIL="aibot@tbnpr.de"
BASEROW_PASSWORD="your-baserow-password"

# n8n (Workflow Engine)
N8N_WEBHOOK_URL="https://aibot.tbnpr.net/webhook"

# Email (for password reset & verification — optional, auto-verify without it)
# EMAIL_FROM="noreply@llmradar.de"
# RESEND_API_KEY="re_..."

# ─── Stripe Payment ─────────────────────────────────────────────────
# Keys (test mode uses sk_test_ / pk_test_, live mode uses sk_live_ / pk_live_)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs — differ between test and live mode!
# Create matching products/prices in Stripe Dashboard for each environment.
STRIPE_PRICE_STARTER="price_..."   # Starter €99/month
STRIPE_PRICE_PRO="price_..."       # Pro €499/month
# STRIPE_PRICE_MANAGED="price_..."  # Managed €799/month (optional — manual onboarding)

# Google PageSpeed Insights (optional)
# GOOGLE_PAGESPEED_API_KEY="..."
